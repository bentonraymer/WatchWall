{
  "name": "WatchWall",
  "version": "1.0.0",
  "description": "Watch multiple web views simultaneously in a structured grid layout",
  "author": {
    "name": "Benton Raymer",
    "email": "benton.raymer@gmail.com"
  },
  "main": "main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "build:all": "electron-builder -mwl --publish never"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.WatchWall.app",
    "productName": "WatchWall",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.entertainment",
      "icon": "build/icon.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "AudioVideo",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
